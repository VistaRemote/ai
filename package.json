{
  "name": "@vistaremote/ai",
  "version": "0.1.0",
  "private": true,
  "description": "VistaRemote AI workers (BullMQ consumers)",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "tsx src/main.ts",
    "test": "rstest",
    "test:watch": "rstest -w",
